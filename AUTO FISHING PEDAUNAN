local function fireFishCaught()
    if not systemEnabled then return end
    
    -- Original code preserved exactly - NO CHANGES
    game:GetService("ReplicatedStorage"):WaitForChild("FishingEvents"):WaitForChild("FishCaught"):FireServer()
    
    -- Visual feedback only
    fishButton.BackgroundColor3 = Color3.fromRGB(0, 180, 100)
    task.wait(0.05)
    fishButton.BackgroundColor3 = Color3.fromRGB(0, 120, 200)
end

-- ##### AUTO-CAST LOGIC (PRESERVED) #####
local function stopAutoCast()
    if autoTask then
        task.cancel(autoTask)
        autoTask = nil
    end
end

local function startAutoCast()
    stopAutoCast()
    autoTask = task.spawn(function()
        while autoActive and systemEnabled do
            fireFishCaught()
            task.wait(FIXED_SPEED)
        end
        if not systemEnabled then
            autoActive = false
            autoToggle.Text = "⏹ AUTO: OFF"
            autoToggle.BackgroundColor3 = Color3.fromRGB(50, 50, 65)
        end
    end)
end

-- ##### SYSTEM TOGGLE (PRESERVED) #####
local function setSystemState(enabled)
    systemEnabled = enabled
    if enabled then
        systemToggle.Text = "🔘 SYSTEM: ON"
        systemToggle.BackgroundColor3 = Color3.fromRGB(0, 150, 100)
        statusIndicator.BackgroundColor3 = Color3.fromRGB(100, 255, 100)
        statusText.Text = "ACTIVE"
        statusText.TextColor3 = Color3.fromRGB(100, 255, 100)
        fishButton.BackgroundColor3 = Color3.fromRGB(0, 120, 200)
        fishButton.TextTransparency = 0
        
        if autoActive then
            startAutoCast()
        end
    else
        systemToggle.Text = "⚫ SYSTEM: OFF"
        systemToggle.BackgroundColor3 = Color3.fromRGB(100, 60, 60)
        statusIndicator.BackgroundColor3 = Color3.fromRGB(255, 80, 80)
        statusText.Text = "OFF"
        statusText.TextColor3 = Color3.fromRGB(255, 80, 80)
        fishButton.BackgroundColor3 = Color3.fromRGB(80, 80, 100)
        fishButton.TextTransparency = 0.4
        stopAutoCast()
    end
end

systemToggle.MouseButton1Click:Connect(function()
    setSystemState(not systemEnabled)
end)

-- ##### AUTO TOGGLE (PRESERVED) #####
