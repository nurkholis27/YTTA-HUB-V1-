-- ##### DRAG FUNCTIONALITY (ENHANCED) #####
local function canStartDrag()
    return not minimized
end

local function getMousePosition()
    return UserInputService:GetMouseLocation()
end

local function onInputBegan(input, gameProcessed)
    if gameProcessed then return end
    
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        if not canStartDrag() then return end
        
        local mousePos = getMousePosition()
        local frameAbsPos = mainFrame.AbsolutePosition
        local frameSize = mainFrame.AbsoluteSize
        
        -- Check if click is within title bar
        if mousePos.X >= frameAbsPos.X and mousePos.X <= frameAbsPos.X + frameSize.X and
           mousePos.Y >= frameAbsPos.Y and mousePos.Y <= frameAbsPos.Y + TITLE_BAR_HEIGHT then
            dragging = true
            dragStartPosition = mainFrame.Position
            dragStartMousePosition = mousePos
            titleBar.BackgroundTransparency = 0.1
        end
    end
end

local function onInputChanged(input, gameProcessed)
    if gameProcessed then return end
    
    if input.UserInputType == Enum.UserInputType.MouseMovement and dragging then
        if not dragStartPosition or not dragStartMousePosition then return end
        
        local currentMousePos = getMousePosition()
        local delta = currentMousePos - dragStartMousePosition
        
        local newXOffset = dragStartPosition.X.Offset + delta.X
        local newYOffset = dragStartPosition.Y.Offset + delta.Y
        
        -- Apply bounds
        newXOffset = math.clamp(newXOffset, dragBounds.minX, dragBounds.maxX)
        newYOffset = math.clamp(newYOffset, dragBounds.minY, dragBounds.maxY)
        
        mainFrame.Position = UDim2.new(dragStartPosition.X.Scale, newXOffset, dragStartPosition.Y.Scale, newYOffset)
    end
end

local function onInputEnded(input, gameProcessed)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = false
        dragStartPosition = nil
        dragStartMousePosition = nil
        titleBar.BackgroundTransparency = 0.3
    end
end

UserInputService.InputBegan:Connect(onInputBegan)
UserInputService.InputChanged:Connect(onInputChanged)
UserInputService.InputEnded:Connect(onInputEnded)

-- Touch support for mobile
if UserInputService.TouchEnabled then
    UserInputService.TouchStarted:Connect(function(touch, processed)
        if processed then return end
        if not canStartDrag() then return end
        
        local touchPoint = touch.Position
        local frameAbsPos = mainFrame.AbsolutePosition
        local frameSize = mainFrame.AbsoluteSize
        
        if touchPoint.X >= frameAbsPos.X and touchPoint.X <= frameAbsPos.X + frameSize.X and
           touchPoint.Y >= frameAbsPos.Y and touchPoint.Y <= frameAbsPos.Y + TITLE_BAR_HEIGHT then
            dragging = true
            dragStartPosition = mainFrame.Position
            dragStartMousePosition = touchPoint
            titleBar.BackgroundTransparency = 0.1
        end
    end)
    
    UserInputService.TouchMoved:Connect(function(touch, processed)
        if processed then return end
        if dragging and dragStartPosition and dragStartMousePosition then
            local currentPos = touch.Position
            local delta = currentPos - dragStartMousePosition
            
            local newXOffset = dragStartPosition.X.Offset + delta.X
            local newYOffset = dragStartPosition.Y.Offset + delta.Y
            
            newXOffset = math.clamp(newXOffset, dragBounds.minX, dragBounds.maxX)
            newYOffset = math.clamp(newYOffset, dragBounds.minY, dragBounds.maxY)
            
            mainFrame.Position = UDim2.new(dragStartPosition.X.Scale, newXOffset, dragStartPosition.Y.Scale, newYOffset)
        end
    end)
    
    UserInputService.TouchEnded:Connect(function()
        dragging = false
        dragStartPosition = nil
        dragStartMousePosition = nil
        titleBar.BackgroundTransparency = 0.3
    end)
end

-- ##### MINIMIZE FUNCTION #####
local function minimize()
    minimized = true
    local tweenInfo = TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
    local goal = {Size = UDim2.new(0, GUI_WIDTH, 0, GUI_MINIMIZED_HEIGHT)}
    local tween = TweenService:Create(mainFrame, tweenInfo, goal)
    tween:Play()
    contentContainer.Visible = false
    minBtn.Text = "+"
end

local function maximize()
    minimized = false
    contentContainer.Visible = true
    local tweenInfo = TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
    local goal = {Size = UDim2.new(0, GUI_WIDTH, 0, GUI_HEIGHT)}
    local tween = TweenService:Create(mainFrame, tweenInfo, goal)
    tween:Play()
    minBtn.Text = "−"
end

minBtn.MouseButton1Click:Connect(function()
    if minimized then
        maximize()
    else
        minimize()
    end
end)

